# ─── Base de datos ───────────────────────────────────────────────────
# Ruta absoluta o relativa al archivo SQLite. En Render, debe apuntar al
# disco persistente (ver render.yaml). En local, queda junto al proyecto.
DATABASE_PATH=./prestamax.db

# ─── JWT ──────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GENERAR_UN_SECRET_SEGURO_AQUI_MINIMO_32_CARACTERES
JWT_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend URL (CORS / CSP) ───────────────────────────────────────
# En desarrollo: http://localhost:5173
# En producción: https://tu-app.vercel.app
FRONTEND_URL=http://localhost:5173

# ─── Stripe (opcional, para suscripciones SaaS) ──────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
